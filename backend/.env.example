# Copy this file to backend/.env and fill in your values.

# Required. Your Google Cloud project ID, the one registered with Earth Engine.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Required for the AI chat (/query) and result explanations. Get a key at openrouter.ai.
# The wizard and direct /analyze work without it.
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional. Redis for background jobs. The API falls back to synchronous
# execution automatically when Redis is not running.
REDIS_URL=redis://localhost:6379

# Optional. Set in production to your deployed frontend URL for CORS.
# FRONTEND_ORIGIN=https://your-app.vercel.app
