# Copy this file to frontend/.env and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Required. The globe will not render without this.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Required. Where the FastAPI backend is running.
VITE_API_BASE_URL=http://localhost:8000

# Optional. Enables Google sign-in, saved analyses and alerts.
# Leave blank to run without accounts.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
